{
    "compilerOptions": {
      "target": "ES2020",
      "lib": ["DOM", "DOM.Iterable", "ES2020"],
      "module": "commonjs",
      "moduleResolution": "node",
      "jsx": "react-jsx",
      "esModuleInterop": true,
      "skipLibCheck": true,
      "verbatimModuleSyntax": false,
      "types": ["jest", "@testing-library/jest-dom", "node"],
      "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
    },
    "include": ["src/**/*", "jest.setup.ts"]
  }